# WP Remote MCP Server — Environment Variables

# Transport mode: "http" (Railway/production) or "stdio" (Claude Desktop local)
TRANSPORT=http

# Port for HTTP transport (Railway sets this automatically)
PORT=3000

# Option 1: Multi-account via accounts.json file (recommended)
# Create accounts.json in the same directory — see accounts.json.example

# Option 2: Multi-account via environment variable (for Railway/Docker)
# ACCOUNTS_JSON={"digitalberry":{"api_token":"bvsk_xxx_yyy"},"client2":{"api_token":"bvsk_aaa_bbb"}}

# Option 3: Single account via environment variable
# WPREMOTE_API_TOKEN=bvsk_your_public_key_your_secret_key
